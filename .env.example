# ─────────────────────────────────────────────────────────────
# HybridSec Agent — Environment Variables
# COPY this file to .env and fill in your real values.
#   cp .env.example .env
# NEVER commit .env to Git — it is in .gitignore
# ─────────────────────────────────────────────────────────────

# ── LLM API ───────────────────────────────────────────────────
# Set LLM_PROVIDER to: openai | openrouter | gemini | local
LLM_PROVIDER=openai

# Option A: OpenAI (GPT-4o-mini) — paid, best accuracy
OPENAI_API_KEY=sk-your-openai-api-key-here

# Option B: OpenRouter — access 100+ models with one API key (free tier available)
# Get a key at: https://openrouter.ai
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here
OPENROUTER_MODEL=openai/gpt-4o-mini

# Option C: Google Gemini — requires: pip install google-generativeai
# Get a key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza-your-gemini-key-here
GEMINI_MODEL=gemini-1.5-flash

# Option D: Local LLaMA 3 (free, no API key, runs on your server via Ollama)
USE_LOCAL_LLM=false
LOCAL_LLM_URL=http://localhost:11434/api/generate
LOCAL_LLM_MODEL=llama3

# ── NVD CVE API ───────────────────────────────────────────────
# Free API key from: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=your-nvd-api-key-here

# ── Telegram Bot Alerts ───────────────────────────────────────
# Step 1: Open Telegram → search @BotFather → /newbot → get token
# Step 2: Send a message to your bot → visit
#         https://api.telegram.org/bot{TOKEN}/getUpdates → find chat.id
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-telegram-chat-id-here

# ── Email Alerts (SMTP) ───────────────────────────────────────
# Gmail: use an App Password (not your normal password)
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
ALERT_EMAIL=your-alert-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password-here

# ── Flask Security ────────────────────────────────────────────
# Generate a strong secret key:  python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-32-char-string

# ── Admin Access Control ──────────────────────────────────────
# Comma-separated list of IPs allowed to access the dashboard
# Use 0.0.0.0 to allow all (development only — not recommended in production)
ADMIN_WHITELIST_IPS=127.0.0.1,your-static-ip-here

# ── Scanning Schedule ─────────────────────────────────────────
# Time for daily deep scan (24h format, server local time)
DEEP_SCAN_TIME=03:00
# How often to run quick scans (hours)
QUICK_SCAN_INTERVAL_HOURS=6

# ── Database ──────────────────────────────────────────────────
# Leave as default unless you move the database file
DATABASE_PATH=database/hybridsec.db

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
